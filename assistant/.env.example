# ─── Cerebro (OpenAI) ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Modelo barato y bueno en español. Podés subir a gpt-4o si querés.
OPENAI_MODEL=gpt-4o-mini

# Nombre/personalidad del asistente (se usa en el prompt del sistema).
ASSISTANT_NAME=Jarvis

# ─── Ubicación / zona horaria (clima + hora) ─────────────────────────
# Por defecto: Córdoba, Argentina (igual que el panel Flutter).
LOCATION_NAME=Córdoba
LATITUDE=-31.4201
LONGITUDE=-64.1888
TIMEZONE=America/Argentina/Cordoba

# ─── Servidor WebSocket (lo consume el panel Flutter) ────────────────
WS_HOST=127.0.0.1
WS_PORT=8765

# ─── MQTT (luces sobre ESP32 / Sonoff SwitchMan 3G) ─────────────────
# En la Raspberry: MQTT_EMBED_BROKER=true levanta el broker en el puerto 1883.
# El ESP32 se conecta a la IP de la Pi (MQTT_BROKER_BIND=0.0.0.0 escucha en toda la red).
MQTT_EMBED_BROKER=false
MQTT_BROKER_BIND=0.0.0.0
# Cliente del asistente. Vacío + broker embebido = 127.0.0.1 automático.
# Si usás Mosquitto externo, poné su IP/host acá.
MQTT_HOST=
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
# Prefijo de topics (debe coincidir con MQTT_BASE_TOPIC del firmware ESP32).
# Publica/suscribe: home/switchman3g/relay1/set, relay1/state, etc.
# relay1=living, relay2=comedor, relay3=patio
MQTT_LIGHTS_PREFIX=home/switchman3g
MQTT_LIGHTS_ON=ON
MQTT_LIGHTS_OFF=OFF

# ─── Spotify (requiere cuenta Premium para controlar reproducción) ───
# Creá una app en https://developer.spotify.com/dashboard
# Si cambiás permisos, borrá assistant/.spotify_cache y reiniciá para re-autorizar.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
SPOTIFY_MARKET=AR
