# ─── Cerebro (OpenAI) ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Modelo barato y bueno en español. Podés subir a gpt-4o si querés.
OPENAI_MODEL=gpt-4o-mini

# Voz (Paso B). STT = transcripción, TTS = voz de respuesta.
OPENAI_STT_MODEL=whisper-1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
# Voces OpenAI: alloy, echo, fable, onyx, nova, shimmer, coral, sage, ash...
OPENAI_TTS_VOICE=coral
# Umbral de silencio para el micrófono (más alto = menos sensible al ruido).
MIC_SILENCE_THRESHOLD=500
# Segundos de silencio que tolera MIENTRAS hablás antes de cortar (pausas entre palabras).
MIC_SILENCE_HANGOVER=2.0
# Duración máxima de un comando de voz (segundos).
MIC_MAX_RECORD_SECONDS=15
# Índice o nombre parcial del micrófono. Vacío = auto-detecta el mejor.
# Ej: MIC_DEVICE=9   o   MIC_DEVICE=Realtek
MIC_DEVICE=

# ─── Proveedor de voz (TTS) ──────────────────────────────────────────
# openai (por defecto) | elevenlabs (voz clonada / personalizada)
TTS_PROVIDER=openai
# ElevenLabs: creá la voz (o clonala) en https://elevenlabs.io y copiá su ID.
# La salida PCM requiere plan pago (el clonado ya lo requiere igual).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2
# Ajustes de voz (0.0–1.0 salvo speed). Valores Jarvis recomendados abajo.
ELEVENLABS_STABILITY=0.78
ELEVENLABS_SIMILARITY=0.82
ELEVENLABS_STYLE=0.08
ELEVENLABS_SPEED=0.92
ELEVENLABS_SPEAKER_BOOST=true

# ─── Wake word (manos libres) ─────────────────────────────────────────
# openwakeword = gratis, incluye "hey_jarvis", sin cuenta (recomendado).
# porcupine = Picovoice (requiere AccessKey; a veces pide email de empresa).
WAKE_WORD_ENABLED=true
WAKE_WORD_BACKEND=openwakeword
WAKE_WORD_MODEL=hey_jarvis
# Umbral 0.35–0.45 suele ir bien. Muy bajo (0.24) = falsos positivos y eco.
WAKE_WORD_THRESHOLD=0.38
# Segundos de silencio tras responder antes de volver a escuchar (evita auto-disparo).
WAKE_WORD_COOLDOWN=4.0
# Frames seguidos por encima del umbral para confirmar (cada frame ≈ 80 ms).
WAKE_WORD_CONFIRM_FRAMES=3
# Frames que se descartan al reanudar (limpia eco del altavoz).
WAKE_WORD_WARMUP_FRAMES=6
# Mínimo entre dos activaciones (segundos).
WAKE_WORD_MIN_INTERVAL=8.0

# Solo si WAKE_WORD_BACKEND=porcupine:
PICOVOICE_ACCESS_KEY=
WAKE_WORD_KEYWORD_PATH=
WAKE_WORD_MODEL_PATH=
WAKE_WORD_SENSITIVITY=0.6

# Nombre/personalidad del asistente (se usa en el prompt del sistema).
ASSISTANT_NAME=Jarvis

# ─── Ubicación / zona horaria (clima + hora) ─────────────────────────
# Por defecto: Córdoba, Argentina (igual que el panel Flutter).
LOCATION_NAME=Córdoba
LATITUDE=-31.4201
LONGITUDE=-64.1888
TIMEZONE=America/Argentina/Cordoba

# ─── Servidor WebSocket (lo consume el panel Flutter) ────────────────
WS_HOST=127.0.0.1
WS_PORT=8765

# ─── MQTT (luces sobre ESP32) ────────────────────────────────────────
# Si dejás MQTT_HOST vacío, las luces corren en modo SIMULADO (solo loguea).
MQTT_HOST=
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
# Prefijo de los topics. El área se agrega al final: p.ej. home/luces/living/set
MQTT_LIGHTS_PREFIX=home/luces
MQTT_LIGHTS_ON=ON
MQTT_LIGHTS_OFF=OFF

# ─── Spotify (requiere cuenta Premium para controlar reproducción) ───
# Creá una app en https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
SPOTIFY_MARKET=AR
